<UserControl x:Class="LabGuard.Host.TopologyView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:LabGuard.Host"
    Height="Auto" Width="Auto">
    <Grid Background="#0F172A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,20,0,10" VerticalAlignment="Center">
            <CheckBox x:Name="SimulationToggle" Content="Simulate Activity (Demo)" 
                      Checked="OnSimulationToggle" Unchecked="OnSimulationToggle"
                      FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" 
                      Foreground="White"/>
            <TextBlock Text=" - Visualize with mock data" 
                       Foreground="#94A3B8" Margin="5,0,0,0" VerticalAlignment="Center" FontStyle="Italic"/>

            <TextBox x:Name="SearchBox" Width="200" Margin="30,0,0,0" VerticalAlignment="Center" 
                     TextChanged="OnSearchChanged" Padding="5" Background="#1E293B" Foreground="White" BorderBrush="#334155"/>

            <CheckBox x:Name="MisuseOnlyFilter" Content="Show Misuse Only" VerticalAlignment="Center" Margin="20,0,0,0"
                      Checked="OnFilterChanged" Unchecked="OnFilterChanged" Foreground="White"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Grid Margin="16">
                <Canvas x:Name="BusCanvas" Height="300">
                    <!-- Bus line and nodes drawn in code-behind -->
                </Canvas>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
