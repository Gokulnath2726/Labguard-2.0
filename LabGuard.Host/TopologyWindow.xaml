<Window x:Class="LabGuard.Host.TopologyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LabGuard.Host"
        Title="Topology View" Height="600" Width="1100">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#FFFFFF" Margin="8" VerticalAlignment="Top">
            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="4" />
            <TextBox x:Name="SearchBox" Width="180" Margin="4" />
            <CheckBox x:Name="ShowMisuseOnly" Content="Show Misuse Only" Margin="8,0" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                <Rectangle Width="14" Height="14" Fill="Green" Stroke="Black" Margin="4" />
                <TextBlock Text="Normal" VerticalAlignment="Center" Margin="2,0" />
                <Rectangle Width="14" Height="14" Fill="Red" Stroke="Black" Margin="12,4,4,4" />
                <TextBlock Text="Misuse" VerticalAlignment="Center" Margin="2,0" />
                <Rectangle Width="14" Height="14" Fill="Gray" Stroke="Black" Margin="12,4,4,4" />
                <TextBlock Text="Offline" VerticalAlignment="Center" Margin="2,0" />
            </StackPanel>
        </StackPanel>

        <local:TopologyView x:Name="TopologyViewControl" />
    </DockPanel>
</Window>
